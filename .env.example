# ===========================================
# Cultural Prediction Market Platform
# Environment Configuration Template
# ===========================================

# Application
NODE_ENV=development
APP_NAME=market-predict
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000
REALTIME_URL=ws://localhost:4001
AI_ENGINE_URL=http://localhost:8000

# Database - PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/market_predict?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# OAuth - Kakao
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:4000/auth/kakao/callback

# OAuth - Google (future)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Engine
AI_ENGINE_API_KEY=your-ai-engine-api-key
OPENAI_API_KEY=your-openai-api-key

# External APIs
TMDB_API_KEY=your-tmdb-api-key
YOUTUBE_API_KEY=your-youtube-api-key
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Storage
S3_BUCKET=market-predict-assets
S3_REGION=ap-northeast-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Market Engine
DEFAULT_LIQUIDITY_PARAM=100
MIN_TRADE_AMOUNT=1
MAX_TRADE_AMOUNT=10000
MARKET_FEE_PERCENT=0.02

# Monitoring
SENTRY_DSN=
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin
ADMIN_DEFAULT_EMAIL=admin@market-predict.com
ADMIN_DEFAULT_PASSWORD=change-this-password

# Feature Flags
ENABLE_AI_PRIORS=true
ENABLE_REALTIME=true
ENABLE_ANALYTICS=true
