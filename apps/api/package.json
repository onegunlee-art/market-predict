{
  "name": "@market-predict/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify API server for Market Predict",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@market-predict/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@market-predict/database": "workspace:*",
    "@market-predict/market-engine": "workspace:*",
    "@market-predict/shared-types": "workspace:*",
    "@market-predict/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.1",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2",
    "pino": "^8.18.0",
    "zod": "^3.22.4"
  }
}
