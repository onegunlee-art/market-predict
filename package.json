{
  "name": "market-predict",
  "version": "0.1.0",
  "private": true,
  "description": "A realtime cultural prediction exchange platform",
  "keywords": [
    "prediction-market",
    "cultural-forecasting",
    "realtime",
    "k-pop",
    "entertainment"
  ],
  "license": "UNLICENSED",
  "author": "Market Predict Team",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@market-predict/web",
    "dev:admin": "turbo run dev --filter=@market-predict/admin",
    "dev:api": "turbo run dev --filter=@market-predict/api",
    "dev:realtime": "turbo run dev --filter=@market-predict/realtime",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@market-predict/web",
    "build:admin": "turbo run build --filter=@market-predict/admin",
    "build:api": "turbo run build --filter=@market-predict/api",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "turbo run db:generate --filter=@market-predict/database",
    "db:migrate": "turbo run db:migrate --filter=@market-predict/database",
    "db:push": "turbo run db:push --filter=@market-predict/database",
    "db:seed": "turbo run db:seed --filter=@market-predict/database",
    "db:studio": "turbo run db:studio --filter=@market-predict/database",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:turbo": "rm -rf .turbo && rm -rf node_modules/.cache"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.14.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
